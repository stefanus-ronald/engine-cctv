# ═══════════════════════════════════════
# ENGINE-CCTV Configuration
# ═══════════════════════════════════════

# Server
PORT=3000

# go2rtc (WebRTC engine)
GO2RTC_API_PORT=1984
GO2RTC_WEBRTC_PORT=8555
GO2RTC_BIN=./bin/go2rtc.exe

# FFmpeg (MJPEG engine)
FFMPEG_BIN=ffmpeg
MJPEG_FPS=10
MJPEG_QUALITY=5

# Default camera (optional — cameras.json is the primary source)
# RTSP_URL=rtsp://admin:password@192.168.1.100:554/Streaming/Channels/101
